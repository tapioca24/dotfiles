abbr "d"="docker"
abbr "dc"="docker compose"
abbr "drb"="sudo darwin-rebuild build --flake ~/.config/nix-darwin#$(scutil --get LocalHostName)"
abbr "drl"="sudo darwin-rebuild switch --list-generations"
abbr "drr"="sudo darwin-rebuild switch --rollback"
abbr "drs"="sudo darwin-rebuild switch --flake ~/.config/nix-darwin#$(scutil --get LocalHostName)"
abbr "dru"="nix flake update --flake ~/.config/nix-darwin"
abbr "g"="git"
abbr "git a"="git add"
abbr "git b"="git branch"
abbr "git bd"="git branch --delete --force"
abbr "git cf"="git clean -d --force"
abbr "git ci"="git commit"
abbr "git cia"="git commit --amend"
abbr "git ciam"="git commit --amend --message \"%\""
abbr "git cim"="git commit --message \"%\""
abbr "git cl"="git config --list"
abbr "git co"="git checkout"
abbr "git cp"="git cherry-pick"
abbr "git d"="git diff"
abbr "git fu"="git commit --fixup"
abbr "git g"="git log --graph --date=short --decorate=short --pretty=format:'%%Cgreen%h %Creset%cd %C(cyan)%cn %Cred%d %Creset%s'"
abbr "git ga"="git log --graph --date=short --decorate=short --pretty=format:'%%Cgreen%h %Creset%cd %C(cyan)%cn %Cred%d %Creset%s' --all"
abbr "git m"="git merge"
abbr "git pl"="git pull"
abbr "git ps"="git push"
abbr "git psf"="git push --force-with-lease --force-if-includes"
abbr "git rb"="git rebase"
abbr "git rba"="git rebase --abort"
abbr "git rbc"="git rebase --continue"
abbr "git rbi"="git rebase --interactive"
abbr "git re"="git restore"
abbr "git res"="git restore --staged"
abbr "git s"="git status --branch"
abbr "git ss"="git status --branch --short"
abbr "git st"="git stash --branch --include-untracked"
abbr "git sta"="git stash apply"
abbr "git stl"="git stash list"
abbr "git stp"="git stash pop"
abbr "git sw"="git switch"
abbr "git swc"="git switch --create"
abbr "jg"="just -g"
abbr "jig"="just -g --choose"
abbr "sz"="source ~/.zshrc"
